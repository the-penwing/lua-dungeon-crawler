#!/usr/bin/env bash
mkdir -p bundles && for arch_dir in dist/*; do \
  arch=$(basename "$arch_dir"); \
  echo "Bundling $arch..."; \
  if [[ "$arch" == *"windows"* ]]; then \
    (cd "$arch_dir" && zip -q -r "../../bundles/blackjack-$arch.zip" ./*); \
  else \
    (cd "$arch_dir" && tar -czf "../../bundles/blackjack-$arch.tar.gz" ./*); \
  fi \
done
